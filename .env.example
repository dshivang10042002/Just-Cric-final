# Client (exposed to the browser at build time via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Server (used by SSR / server functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Deployment target for `vite build`
# - vercel       -> Vercel Build Output (used by vercel.json)
# - node-server  -> Standalone Node server in .output/ (used by Render & local prod)
# - cloudflare-module -> Cloudflare Workers
NITRO_PRESET=node-server
